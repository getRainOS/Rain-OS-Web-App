modules = ["php-8.2", "nodejs-20", "python-3.11"]
[nix]
channel = "stable-25_05"
packages = ["unzip", "zip"]

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Build Plugin"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Package Plugin"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Web App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Marketing Page"

[[workflows.workflow]]
name = "Build Plugin"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd \"rain OS AI Readability Optimizer/rain-os-aeo-analyzer\" && npm run build:replit"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Package Plugin"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd \"rain OS AI Readability Optimizer/rain-os-aeo-analyzer\" && npm run zip:wporg"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Web App"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd web-app && npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Marketing Page"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd \"rain OS AI Readability Optimizer/dashboard-preview\" && npm run dev"
waitForPort = 5173

[[ports]]
localPort = 3000

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3003

[[ports]]
localPort = 5173
externalPort = 5173

[[ports]]
localPort = 5174
externalPort = 3002

[deployment]
deploymentTarget = "static"
build = ["npm", "run", "build"]
publicDir = "web-app/dist"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
