modules = ["php-8.2", "nodejs-20"]
[nix]
channel = "stable-25_05"
packages = ["unzip"]

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Dashboard Preview"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "PHP Plugin Preview"

[[workflows.workflow]]
name = "Dashboard Preview"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd WordpressPluginStudio/dashboard-preview && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "PHP Plugin Preview"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd WordpressPluginStudio/preview && php -S 0.0.0.0:8000"
waitForPort = 8000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 8000
externalPort = 8000
