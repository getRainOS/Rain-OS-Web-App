modules = ["php-8.2", "nodejs-20"]
[nix]
channel = "stable-25_05"
packages = ["unzip"]

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Preview rain OS SEO"

[[workflows.workflow]]
name = "Preview rain OS SEO"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd WordpressPluginStudio/preview && php -S 0.0.0.0:5000"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80
